# ============================================================
# Pharos x402 Payments — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# Server/facilitator wallet — receives payments
# NEVER share this key with any LLM or external service
SERVER_PRIVATE_KEY=0xYOUR_SERVER_PRIVATE_KEY_HERE

# Client wallet — pays for access
# NEVER share this key with any LLM or external service
CLIENT_PRIVATE_KEY=0xYOUR_CLIENT_PRIVATE_KEY_HERE

# Pharos Atlantic Testnet
RPC_URL=https://atlantic.dplabs-internal.com
NETWORK_ID=eip155:688689
CHAIN_ID=688689

# Payment token address — CONFIGURE EXPLICITLY
# For testing (unofficial x402 test token — NOT canonical USDC):
#   0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8
# For production (official Pharos testnet USDC):
#   0xcfC8330f4BCAB529c625D12781b1C19466A9Fc8B
PAYMENT_TOKEN_ADDRESS=0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8

# Facilitator — use public one or run your own (facilitator.ts)
# Public: https://facilitator.x402.org (supports common EVM chains)
# Self-hosted: http://localhost:3001
FACILITATOR_URL=https://facilitator.x402.org

# Server
SERVER_PORT=3000

# Self-hosted facilitator (only if running facilitator.ts)
FACILITATOR_PORT=3001

# Client session spend cap — number of payments allowed per session
CLIENT_SPEND_CAP=100

# Target server URL for client
SERVER_URL=http://localhost:3000
