{
  "name": "pharos-skills",
  "version": "1.2.1",
  "description": "CLI installer for Pharos Skills — composable on-chain operation primitives for the Pharos Network",
  "type": "module",
  "bin": {
    "pharos-skills": "cli/dist/index.js"
  },
  "files": [
    "cli/dist/",
    "skills/",
    "shared/"
  ],
  "scripts": {
    "build": "npm run build --workspace=cli",
    "test": "npm run test --workspace=cli",
    "prepublishOnly": "npm run build"
  },
  "workspaces": ["cli"],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pharos",
    "blockchain",
    "solidity",
    "foundry",
    "erc20",
    "erc721",
    "erc1155",
    "gnosis-safe",
    "x402",
    "skills",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SachPlayZ/pharos-skills.git"
  },
  "license": "MIT"
}
