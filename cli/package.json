{
  "name": "pharos-skills",
  "version": "1.1.0",
  "description": "CLI installer for Pharos Skills — composable on-chain operation primitives",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pharos-skills": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "files": [
    "dist/",
    "../skills/",
    "../shared/"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pharos",
    "blockchain",
    "solidity",
    "foundry",
    "erc20",
    "erc721",
    "erc1155",
    "gnosis-safe",
    "x402",
    "skills",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sachplayz/pharos-skills"
  },
  "license": "MIT"
}
